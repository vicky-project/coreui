{
  "name": "vicky-project/coreui-module",
  "type":"laravel-module",
  "license": "MIT",
  "description": "",
  "authors": [{
    "name": "Vicky Rahman",
    "email": "pratamavr@gmail.com"
  }],
  "require": {
    "php": "^8.0",
    "nwidart/laravel-modules": "^12.0",
    "predis/predis": "^3.2",
    "joshbrw/laravel-module-installer": "^1.0"
  },
  "extra": {
    "laravel": {
      "providers": ["Modules\\CoreUI\\Providers\\CoreUIServiceProvider"],
      "aliases": {}
    }
  },
  "autoload": {
    "psr-4": {
      "Modules\\CoreUI\\": "app/",
      "Modules\\CoreUI\\Database\\Factories\\": "database/factories/",
      "Modules\\CoreUI\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Modules\\CoreUI\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "@php artisan app:install"
    ]
  }
}